NODE_ENV=development
DATABASE_URL=postgresql://chatcade:your-db-password@localhost:5432/chatcade
JWT_SECRET=

# Per-service ports
AUTH_PORT=3001
USERS_PORT=3002
CHANNELS_PORT=3003
MESSAGES_PORT=3004
FRIENDS_PORT=3005
GAMES_PORT=3006

# Per-service names
AUTH_SERVICE_NAME=auth
USERS_SERVICE_NAME=users
CHANNELS_SERVICE_NAME=channels
MESSAGES_SERVICE_NAME=messages
FRIENDS_SERVICE_NAME=friends
GAMES_SERVICE_NAME=games

# WebSocket Lambdas share the same DATABASE_URL — no separate service name/port needed