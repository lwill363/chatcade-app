# Prod credentials for populating AWS SSM Parameter Store.
# This file is for the infrastructure owner only — developers do not need it.
# Copy to .env.ssm, fill in values, run ./create-ssm-params.sh, then delete .env.ssm.
#
# .env.ssm is gitignored. Never commit it.
# Re-run the script any time values change — existing parameters are overwritten.

CHATCADE_ENV=prod
AWS_REGION=us-east-1
NODE_ENV=production

# RDS credentials (used by Terraform to create the database)
DB_USERNAME=chatcade
DB_PASSWORD=

# Shared JWT secret (same value used across all services)
JWT_SECRET=

# Full RDS connection string for all services + migrations.
# Fill in the RDS endpoint after the first terraform apply.
DATABASE_URL=postgresql://chatcade:your-db-password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/chatcade

# Per-service ports
AUTH_PORT=3001
USERS_PORT=3002
CHANNELS_PORT=3003
MESSAGES_PORT=3004
FRIENDS_PORT=3005
GAMES_PORT=3006

# Per-service names
AUTH_SERVICE_NAME=auth
USERS_SERVICE_NAME=users
CHANNELS_SERVICE_NAME=channels
MESSAGES_SERVICE_NAME=messages
FRIENDS_SERVICE_NAME=friends
GAMES_SERVICE_NAME=games
